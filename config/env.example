# === LLM for summarization (any OpenAI-compatible endpoint) ===
VLLM_BASE_URL=http://host.docker.internal:8000/v1
VLLM_API_KEY=your-api-key
VLLM_MODEL=your-model-name

# === Transcription (WhisperLiveKit) ===
WHISPER_MODEL=TalTechNLP/whisper-large-v3-turbo-et-verbatim
WHISPER_BACKEND=faster-whisper
TRANSCRIPTION_URL=ws://transcription:8000/asr

# === Summarizer ===
SUMMARIZER_URL=http://summarizer:8001

# === Translation (TartuNLP septilang via RabbitMQ) ===
MQ_HOST=rabbitmq
MQ_PORT=5672
MQ_USERNAME=user
MQ_PASSWORD=changeme
MQ_EXCHANGE=translation
MQ_CONNECTION_NAME=Translation worker
MQ_HEARTBEAT=30
NMT_MODEL=septilang

# === PostgreSQL ===
POSTGRES_DB=meetings
POSTGRES_USER=meetings
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://meetings:changeme@postgres:5432/meetings

# === API ===
API_HOST=0.0.0.0
API_PORT=8080

# === Azure Entra ID (SSO) ===
AZURE_CLIENT_ID=your-web-app-client-id
AZURE_TENANT_ID=your-tenant-id
NEXT_PUBLIC_AZURE_CLIENT_ID=your-web-app-client-id
NEXT_PUBLIC_AZURE_TENANT_ID=your-tenant-id

# === Audio Ingestion (gRPC) ===
GRPC_PORT=50051
